# Radar 36 Sales CRM - Environment Variables
# Copy this to .env and fill in your values

# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=radar36_crm
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optionals for custom deployments (like Azure AI Foundry/Studio):
# ANTHROPIC_BASE_URL=https://saura-mrc7ezob.services.ai.azure.com/anthropic/
# ANTHROPIC_MODEL=claude-opus-4-7

OPENAI_API_KEY=your-openai-api-key
AI_DEFAULT_PROVIDER=claude
AI_CLAUDE_MODEL=claude-3-5-sonnet-20241022
AI_OPENAI_MODEL=gpt-4o

# Deployment URL settings (needed for invitation links and branding logos)
# When deploying to a server, replace localhost with your server's IP address or domain:
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:8000

# When deploying to a server, set DJANGO_ALLOWED_HOSTS=* to accept connections from your IP
# DJANGO_ALLOWED_HOSTS=*
